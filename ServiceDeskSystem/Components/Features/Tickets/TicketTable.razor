@using ServiceDeskSystem.Domain.Entities

@inherits ServiceDeskSystem.Components.UI.Base.BaseComponent

@* ─── Mobile Card View (visible only on small screens) ─── *@
<div class="space-y-3 md:hidden">
    @foreach (var ticket in Tickets)
    {
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700/50 p-4 active:bg-gray-50 dark:active:bg-gray-700/50 transition-colors cursor-pointer"
             @onclick="@(() => OnTicketClick.InvokeAsync(ticket.Id))">
            <div class="flex items-start justify-between gap-3 mb-3">
                <div class="min-w-0 flex-1">
                    <p class="text-sm font-semibold text-gray-900 dark:text-white truncate">@ticket.Title</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 font-mono">#@ticket.Id</p>
                </div>
                <span class="@GetStatusBadgeClass(ticket.Status) px-2.5 py-1 rounded-full text-xs font-semibold whitespace-nowrap flex-shrink-0">
                    @GetStatusText(ticket.Status)
                </span>
            </div>
            <div class="flex items-center flex-wrap gap-2 text-xs">
                <span class="@GetPriorityBadgeClass(ticket.Priority) px-2 py-0.5 rounded-lg font-semibold">
                    @GetPriorityText(ticket.Priority)
                </span>
                @if (ShowProduct && ticket.Product is not null)
                {
                    <span class="text-gray-500 dark:text-gray-400">@ticket.Product.Name</span>
                }
                @if (ShowAssignee)
                {
                    @if (ticket.Developer is not null)
                    {
                        <span class="text-green-600 dark:text-green-400 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            @ticket.Developer.Login
                        </span>
                    }
                    else
                    {
                        <span class="text-gray-400 dark:text-gray-500 italic">@L.Translate("table.unassigned")</span>
                    }
                }
                <span class="text-gray-400 dark:text-gray-500 ml-auto">@ticket.CreatedAt.ToString("MMM dd")</span>
            </div>
        </div>
    }
</div>

@* ─── Desktop Table View (hidden on small screens) ─── *@
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hidden md:block">
    <div class="overflow-x-auto">
        <table class="w-full ticket-table">
            <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700/50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.id")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.title")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.status")</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.priority")</th>
                    @if (ShowProduct)
                    {
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.product")</th>
                    }
                    @if (ShowAuthor)
                    {
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.author")</th>
                    }
                    @if (ShowAssignee)
                    {
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.assignee")</th>
                    }
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">@L.Translate("table.created")</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700/50">
                @foreach (var ticket in Tickets)
                {
                            <tr class="hover:bg-blue-100 dark:hover:bg-blue-900/20 cursor-pointer transition-colors" @onclick="@(() => OnTicketClick.InvokeAsync(ticket.Id))">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300 font-mono">#@ticket.Id</td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 truncate max-w-xs">@ticket.Title</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="@GetStatusBadgeClass(ticket.Status) px-3 py-1 rounded-full text-xs font-semibold">
                                @GetStatusText(ticket.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="@GetPriorityBadgeClass(ticket.Priority) px-3 py-1 rounded-lg text-xs font-semibold">
                                @GetPriorityText(ticket.Priority)
                                    </span>
                                </td>
                        @if (ShowProduct)
                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300 truncate max-w-[120px]">@(ticket.Product?.Name ?? L.Translate("table.noProduct"))</td>
                        }
                        @if (ShowAuthor)
                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300 truncate max-w-[100px]">@ticket.Author?.Login</td>
                        }
                        @if (ShowAssignee)
                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (ticket.Developer is not null)
                                {
                                                            <span class="flex items-center gap-1.5 text-green-600 dark:text-green-400">
                                                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                                </svg>
                                        @ticket.Developer.Login
                                                            </span>
                                }
                                else
                                {
                                                            <span class="text-gray-400 dark:text-gray-500 italic">@L.Translate("table.unassigned")</span>
                                }
                                            </td>
                        }
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                }
            </tbody>
        </table>
    </div>
</div>
