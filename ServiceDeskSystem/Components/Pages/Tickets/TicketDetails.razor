@page "/ticket/{Id:int}"
@using ServiceDeskSystem.Components.Features
@inherits BaseComponent
@rendermode InteractiveServer

<!-- Created by Nazar "N1h3" Hutsol -->
<ToastContainer Toasts="@Toasts" OnRemoveToast="@RemoveToastAsync" />

<div class="max-w-6xl mx-auto p-4 sm:p-6">
    @if (Ticket is null)
    {
        <div class="animate-pulse space-y-6">
            <!-- Header Skeleton -->
            <div class="bg-white dark:bg-gray-800/80 rounded-2xl p-6 sm:p-8 shadow-sm">
                <div class="flex items-start justify-between mb-4">
                    <div class="h-8 bg-gray-200 dark:bg-gray-700 rounded w-2/3"></div>
                    <div class="h-6 bg-gray-200 dark:bg-gray-700 rounded-full w-24"></div>
                </div>
                <div class="flex gap-4 mb-4">
                    <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-24"></div>
                    <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-32"></div>
                    <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-16"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Main Content Skeleton -->
                <div class="lg:col-span-2 space-y-6">

                <!-- Comments Skeleton -->
                <div class="bg-white dark:bg-gray-800/80 rounded-lg p-6">
                    <div class="h-6 bg-gray-200 dark:bg-gray-700 rounded w-1/4 mb-6"></div>
                    <div class="space-y-4">
                        <div class="border-l-4 border-gray-200 dark:border-gray-700 pl-4 space-y-2">
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-32"></div>
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-full"></div>
                        </div>
                        <div class="border-l-4 border-gray-200 dark:border-gray-700 pl-4 space-y-2">
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-32"></div>
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Skeleton -->
            <div class="space-y-6">
                <div class="bg-white dark:bg-gray-800/80 rounded-lg p-6">
                    <div class="h-6 bg-gray-200 dark:bg-gray-700 rounded w-1/3 mb-4"></div>
                    <div class="space-y-4">
                        <div>
                            <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16 mb-1"></div>
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-24"></div>
                        </div>
                        <div>
                            <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16 mb-1"></div>
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-20"></div>
                        </div>
                        <div>
                            <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16 mb-1"></div>
                            <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-24"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>
    }
    else
    {
        <div class="space-y-6">
            <!-- Ticket Premium Header -->
            <div class="relative overflow-hidden bg-white dark:bg-gradient-to-br dark:from-gray-900 dark:via-gray-800 dark:to-slate-900 rounded-2xl p-6 sm:p-8 shadow-md dark:shadow-xl border border-gray-200 dark:border-gray-700/50">
                <!-- Decorative background blur -->
                <div class="absolute top-0 right-0 -m-8 w-40 h-40 bg-blue-400/20 dark:bg-blue-500/30 rounded-full filter blur-3xl animate-pulse"></div>
                <div class="absolute bottom-0 left-0 -m-8 w-40 h-40 bg-purple-400/20 dark:bg-purple-500/30 rounded-full filter blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
                
                <div class="relative z-10">
                    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-6">
                        <div class="flex-1">
                            <div class="flex flex-wrap items-center gap-3 mb-3">
                                <span class="px-2.5 py-1 rounded-md bg-gray-100 dark:bg-black/40 backdrop-blur-md border border-gray-200 dark:border-white/10 text-gray-700 dark:text-blue-100 font-mono text-sm shadow-sm flex items-center gap-1.5 font-semibold">
                                    <svg class="w-3.5 h-3.5 text-blue-500 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                                    @Ticket.Id
                                </span>
                                <span class="@GetStatusBadgeClass(Ticket.Status) px-3 py-1 rounded-full text-sm font-semibold whitespace-nowrap shadow-sm">
                                    @GetStatusText(Ticket.Status)
                                </span>
                                <span class="@GetPriorityBadgeClass(Ticket.Priority) px-3 py-1 rounded-full text-sm font-semibold whitespace-nowrap shadow-sm hidden sm:inline-flex">
                                    @GetPriorityText(Ticket.Priority)
                                </span>
                            </div>
                            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white break-words leading-tight tracking-tight drop-shadow-sm dark:drop-shadow-md">@Ticket.Title</h1>
                        </div>
                        
                        @if (CanManageTicket)
                        {
                            <button @onclick="DeleteTicketAsync" class="flex items-center justify-center gap-2 px-4 py-2.5 bg-red-50 dark:bg-red-500/10 hover:bg-red-100 dark:hover:bg-red-500/20 text-red-600 dark:text-red-100 border border-red-200 dark:border-red-500/30 rounded-xl transition-all shadow-sm backdrop-blur-md whitespace-nowrap group" type="button">
                                <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                                <span class="font-medium text-sm">@L.Translate("details.deleteTicket")</span>
                            </button>
                        }
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-blue-100/90 bg-gray-50 dark:bg-black/20 p-3 rounded-xl border border-gray-100 dark:border-white/5 backdrop-blur-sm inline-flex shadow-sm dark:shadow-inner">
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 dark:from-blue-400 dark:to-purple-500 flex items-center justify-center text-white text-xs font-bold ring-2 ring-white dark:ring-white/20 shadow-sm">
                                @(Ticket.Author?.Login?.Substring(0, 1).ToUpper() ?? "?")
                            </div>
                            <span class="font-medium text-gray-800 dark:text-white">@Ticket.Author?.Login</span>
                        </div>
                        <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-blue-400/50"></div>
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-gray-400 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            @Ticket.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                        </span>
                        <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-blue-400/50 sm:hidden"></div>
                        <span class="sm:hidden @GetPriorityBadgeClass(Ticket.Priority) px-2 py-0.5 rounded-md text-xs font-semibold shadow-sm">
                            @GetPriorityText(Ticket.Priority)
                        </span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Main Content -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Description & Steps -->
                <div class="bg-white dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-md border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <div class="p-6 sm:p-8">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                                </svg>
                            </div>
                            <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100">@L.Translate("details.description")</h3>
                        </div>
                        <div class="prose prose-sm sm:prose-base dark:prose-invert max-w-none text-gray-600 dark:text-gray-300 whitespace-pre-wrap leading-relaxed bg-slate-50 dark:bg-slate-900/30 p-5 rounded-xl border border-slate-100 dark:border-slate-700/50">@Ticket.Description</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Ticket.StepsToReproduce))
                    {
                        <div class="border-t border-gray-100 dark:border-gray-700/50 p-6 sm:p-8 bg-slate-50/50 dark:bg-slate-800/30">
                            <div class="flex items-center gap-2 mb-4">
                                <div class="p-2 bg-purple-50 dark:bg-purple-900/20 rounded-lg">
                                    <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100">@L.Translate("details.stepsToReproduce")</h3>
                            </div>
                            <div class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap bg-white dark:bg-gray-900 shadow-inner rounded-xl p-5 text-sm font-mono border border-gray-200 dark:border-gray-700 leading-relaxed overflow-x-auto">@Ticket.StepsToReproduce</div>
                        </div>
                    }
                </div>

                <!-- Comments Section -->
                <div class="bg-white dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-md border border-gray-200 dark:border-gray-700 p-6 sm:p-8">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100 dark:border-gray-700/50">
                        <div class="p-2 bg-indigo-50 dark:bg-indigo-900/20 rounded-lg">
                            <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                            </svg>
                        </div>
                        <h2 class="text-xl font-bold text-gray-800 dark:text-white">
                            @L.Translate("details.comments")
                            <span class="ml-2 inline-flex items-center justify-center bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-sm py-0.5 px-2.5 rounded-full font-medium">@(Ticket.Comments?.Count ?? 0)</span>
                        </h2>
                    </div>

                    @if (Ticket.Comments is not null && Ticket.Comments.Any())
                    {
                        <div class="relative pl-6 mb-6">
                            <!-- Timeline vertical line -->
                            <div class="absolute left-[9px] top-2 bottom-2 w-0.5 bg-gradient-to-b from-blue-400 via-blue-300 to-transparent dark:from-blue-500 dark:via-blue-700 dark:to-transparent"></div>

                            @foreach (var comment in Ticket.Comments.OrderBy(c => c.CreatedAt))
                            {
                                <div class="relative mb-5 last:mb-0">
                                    <!-- Timeline dot -->
                                    <div class="absolute -left-6 top-1 w-[18px] h-[18px] rounded-full border-2 border-blue-400 dark:border-blue-500 bg-white dark:bg-gray-800 flex items-center justify-center">
                                        <div class="w-2 h-2 rounded-full bg-blue-400 dark:bg-blue-500"></div>
                                    </div>

                                    <div class="bg-gray-50 dark:bg-gray-700/40 rounded-xl p-3 sm:p-4 border border-gray-100 dark:border-gray-700/50 transition-colors hover:border-blue-200 dark:hover:border-blue-800/50">
                                        <div class="flex flex-wrap items-center gap-2 mb-2">
                                            <div class="w-6 h-6 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center flex-shrink-0">
                                                <span class="text-white text-[10px] font-bold">@(comment.Author?.Login?.Substring(0, 1).ToUpper() ?? "?")</span>
                                            </div>
                                            <span class="font-medium text-sm text-gray-800 dark:text-white">@comment.Author?.Login</span>
                                            <span class="text-xs text-gray-400 dark:text-gray-500">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>

                                            @if (CanEditComment(comment) || CanDeleteComment(comment))
                                            {
                                                <div class="ml-auto flex items-center gap-1">
                                                    @if (CanEditComment(comment))
                                                    {
                                                        @if (EditingCommentId == comment.Id)
                                                        {
                                                            <button class="px-2 py-0.5 text-xs rounded bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors" @onclick="() => SaveCommentEditAsync(comment.Id)">@L.Translate("details.commentSave")</button>
                                                            <button class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-600 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-500 transition-colors" @onclick="CancelEdit">@L.Translate("details.commentCancel")</button>
                                                        }
                                                        else
                                                        {
                                                            <button class="p-1 rounded text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors" @onclick="() => BeginEdit(comment)" title="@L.Translate("details.commentEdit")">
                                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                                            </button>
                                                        }
                                                    }
                                                    @if (CanDeleteComment(comment))
                                                    {
                                                        <button class="p-1 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" @onclick="() => DeleteCommentAsync(comment.Id)" @onclick:stopPropagation="true" title="@L.Translate("details.commentDelete")">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        @if (EditingCommentId == comment.Id)
                                        {
                                            <textarea @bind="EditingCommentMessage" @bind:event="oninput" rows="3"
                                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm"></textarea>
                                        }
                                        else
                                        {
                                            <p class="text-sm text-gray-600 dark:text-gray-300 whitespace-pre-wrap">@comment.Message</p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8 mb-4">
                            <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                            </svg>
                            <p class="text-gray-400 dark:text-gray-500 text-sm">@L.Translate("details.noComments")</p>
                        </div>
                    }

                    <!-- Add Comment Form -->
                    <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
                        <textarea @bind="NewCommentMessage" @bind:event="oninput" rows="3" 
                                  placeholder="@L.Translate("details.writeComment")"
                                  class="w-full px-3 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none bg-gray-50 dark:bg-gray-700/50 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 text-sm transition-colors"></textarea>
                        <div class="flex justify-end mt-2">
                            <button @onclick="AddCommentAsync" 
                                    disabled="@(string.IsNullOrWhiteSpace(NewCommentMessage) || IsSubmitting)"
                                    class="px-4 py-2 bg-gradient-to-r from-blue-600 to-blue-700 text-white text-sm font-medium rounded-lg hover:from-blue-700 hover:to-blue-800 disabled:from-gray-400 disabled:to-gray-400 disabled:cursor-not-allowed transition-all shadow-sm flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                                </svg>
                                @if (IsSubmitting)
                                {
                                    <span>@L.Translate("details.sending")</span>
                                }
                                else
                                {
                                    <span>@L.Translate("details.sendComment")</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Properties Card -->
                <div class="bg-white dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-md border border-gray-200 dark:border-gray-700 p-6 sm:p-8 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/5 dark:bg-indigo-500/10 rounded-full blur-2xl group-hover:bg-indigo-500/10 dark:group-hover:bg-indigo-500/20 transition-colors pointer-events-none"></div>
                    
                    <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-5 flex items-center gap-2 relative z-10">
                        <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        @L.Translate("details.details")
                    </h3>
                    
                    <div class="space-y-4 relative z-10">
                        <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                            <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("table.product")</span>
                            <span class="text-sm font-medium text-gray-800 dark:text-gray-200 text-right max-w-[190px] break-words whitespace-normal leading-5">@(Ticket.Product?.Name ?? L.Translate("table.noProduct"))</span>
                        </div>
                        
                        <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                            <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("table.priority")</span>
                            <span class="ticket-priority-badge @GetPriorityBadgeClass(Ticket.Priority) inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold shadow-sm leading-5">
                                @GetPriorityText(Ticket.Priority)
                            </span>
                        </div>
                        
                        <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                            <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("details.ticketId")</span>
                            <span class="inline-flex items-center text-sm font-mono font-semibold text-gray-800 dark:text-gray-200 bg-gray-100 dark:bg-gray-700/50 px-2.5 py-0.5 rounded-md shadow-inner text-right leading-5">#@Ticket.Id</span>
                        </div>
                        
                        <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                            <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("details.assignedTo")</span>
                            <div class="text-right">
                                @if (Ticket.Developer is not null)
                                {
                                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 px-2.5 py-1 rounded-md leading-5">
                                        <div class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></div>
                                        @Ticket.Developer.Login
                                    </span>
                                }
                                else
                                {
                                    <span class="text-sm text-gray-400 dark:text-gray-500 italic px-2">@L.Translate("table.unassigned")</span>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Ticket.Environment))
                        {
                            <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors border-t border-gray-100 dark:border-gray-700/30 mt-2 pt-4">
                                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("details.environment")</span>
                                <span class="text-sm text-gray-800 dark:text-gray-200 text-right inline-flex items-center justify-end gap-1.5 max-w-[190px] leading-5">
                                    <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                    </svg>
                                    <span class="break-words whitespace-normal" title="@Ticket.Environment">@Ticket.Environment</span>
                                </span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Ticket.AffectedVersion))
                        {
                            <div class="flex items-center justify-between gap-4 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">@L.Translate("details.affectedVersion")</span>
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-md bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-300 text-xs font-semibold shadow-sm text-right leading-5">
                                    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                                    </svg>
                                    <span class="break-words whitespace-normal max-w-[160px]" title="@Ticket.AffectedVersion">@Ticket.AffectedVersion</span>
                                </span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Assign/Unassign Actions -->
                <AssignmentActions 
                    Ticket="@Ticket"
                    CurrentUserId="@CurrentUserId"
                    IsAdminOrDeveloper="@IsAdminOrDeveloper"
                    IsAdmin="@IsAdmin"
                    OnTakeTicket="@AssignToMeAsync"
                    OnReleaseTicket="@UnassignAsync" />

                <!-- Actions -->
                @if (CanManageTicketStatus)
                {
                    <div class="bg-white dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700/50 p-6 relative overflow-hidden group">
                        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-orange-500/5 dark:bg-orange-500/10 rounded-full blur-3xl group-hover:bg-orange-500/10 dark:group-hover:bg-orange-500/20 transition-colors pointer-events-none"></div>
                        
                        <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-5 flex items-center gap-2 relative z-10">
                            <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            @L.Translate("details.actions")
                        </h3>
                        <div class="space-y-3 relative z-10 flex flex-col">
                            @* Start working on ticket *@
                            @if (Ticket.Status == "New" || Ticket.Status == "Open")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("In Progress"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--warning btn-animate">
                                    <span>🚀</span>
                                    <span>@L.Translate("details.startProgress")</span>
                                </button>
                            }
                            
                            @* From In Progress - multiple options *@
                            @if (Ticket.Status == "In Progress")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Testing"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--info btn-animate">
                                    <span>🧪</span>
                                    <span>@L.Translate("details.sendToTesting")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("Code Review"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--violet btn-animate">
                                    <span>👀</span>
                                    <span>@L.Translate("details.sendToCodeReview")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("Resolved"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--success btn-animate">
                                    <span>✅</span>
                                    <span>@L.Translate("details.markResolved")</span>
                                </button>
                            }
                            
                            @* From Testing *@
                            @if (Ticket.Status == "Testing")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Code Review"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--violet btn-animate">
                                    <span>👀</span>
                                    <span>@L.Translate("details.moveToCodeReview")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("Done"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--success btn-animate">
                                    <span>✅</span>
                                    <span>@L.Translate("details.testingPassed")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("In Progress"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--orange btn-animate">
                                    <span>🔙</span>
                                    <span>@L.Translate("details.returnToDevelopment")</span>
                                </button>
                            }
                            
                            @* From Code Review *@
                            @if (Ticket.Status == "Code Review")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Done"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--success btn-animate">
                                    <span>✅</span>
                                    <span>@L.Translate("details.approveChanges")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("In Progress"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--orange btn-animate">
                                    <span>🔙</span>
                                    <span>@L.Translate("details.requestChanges")</span>
                                </button>
                            }
                            
                            @* From Resolved *@
                            @if (Ticket.Status == "Resolved")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Closed"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--neutral btn-animate">
                                    <span>🔒</span>
                                    <span>@L.Translate("details.closeTicketBtn")</span>
                                </button>
                                <button @onclick="@(() => UpdateStatusAsync("In Progress"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--orange btn-animate">
                                    <span>🔙</span>
                                    <span>@L.Translate("details.reopenForChanges")</span>
                                </button>
                            }
                            
                            @* From Done *@
                            @if (Ticket.Status == "Done")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Closed"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--neutral btn-animate">
                                    <span>🔒</span>
                                    <span>@L.Translate("details.markAsClosed")</span>
                                </button>
                            }
                            
                            @* Force Close - from any status except Closed *@
                            @if (Ticket.Status != "Closed" && Ticket.Status != "Done" && Ticket.Status != "Resolved")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Closed"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--danger btn-animate">
                                    <span>⛔</span>
                                    <span>@L.Translate("details.forceClose")</span>
                                </button>
                            }
                            
                            @* Reopen Closed ticket *@
                            @if (Ticket.Status == "Closed")
                            {
                                <button @onclick="@(() => UpdateStatusAsync("Open"))" 
                                        class="action-btn ui-btn ui-btn--block ui-btn--primary-soft btn-animate">
                                    <span>🔓</span>
                                    <span>@L.Translate("details.reopenTicket")</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Navigation -->
                <div class="bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-lg shadow-md border border-transparent dark:border-gray-700/50 p-6">
                    <button @onclick="GoBack" 
                            class="ui-btn ui-btn--block ui-btn--neutral">
                        @L.Translate("details.backToTickets")
                    </button>
                </div>
            </div>
        </div>
        </div>
    }
</div>
