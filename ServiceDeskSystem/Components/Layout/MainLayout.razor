@inherits LayoutComponentBase

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="@(Theme.IsDarkMode ? "dark" : "")">
    @if (!authRestored)
    {
        <div class="flex items-center justify-center h-screen bg-gray-100">
            <div class="text-gray-500">@L.Translate("common.loading")</div>
        </div>
    }
    else if (!AuthService.IsAuthenticated)
    {
        @Body
        <RedirectToLogin />
    }
    else
    {
        <div class="flex h-screen bg-gray-100 dark:bg-gray-900 transition-colors duration-200 overflow-hidden relative">
            @if (isSidebarOpen)
            {
                <div class="fixed inset-0 bg-gray-900/60 dark:bg-black/60 backdrop-blur-sm z-40 lg:hidden transition-opacity duration-300"
                     @onclick="CloseSidebar"></div>
            }

            <aside class="fixed inset-y-0 left-0 z-50 transform transition-all duration-200 ease-out lg:static lg:translate-x-0 @(isSidebarOpen ? "translate-x-0" : "-translate-x-full") @(isSidebarCollapsed ? "w-20 lg:w-20" : "w-72 lg:w-72") shadow-2xl lg:shadow-none flex-shrink-0 overflow-hidden">
                <NavMenu IsCollapsed="isSidebarCollapsed" ToggleCollapseRequested="ToggleSidebarCollapseAsync" />
            </aside>

            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                <header class="sticky top-0 z-30 h-[4.5rem] bg-white dark:bg-gray-800 backdrop-blur-md border-b-2 border-gray-400 dark:border-gray-700 shadow-md shadow-gray-300/70 dark:shadow-black/30 transition-colors duration-200">
                    <div class="flex items-center justify-between px-4 lg:px-6 h-full">
                        <div class="flex items-center gap-4">
                            <button @onclick="ToggleSidebar" class="p-2 -ml-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 lg:hidden focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                                </svg>
                            </button>

                            <div class="hidden sm:block">
                                <p class="text-xs text-gray-500 dark:text-gray-400">@GetHeaderDateText()</p>
                            </div>
                        </div>

                        <div class="header-actions flex items-center gap-2 sm:gap-3">
                            <details class="header-dropdown relative language-dropdown-wrapper" open="@isLanguageDropdownOpen">
                                <summary @onclick="ToggleLanguageDropdownAsync"
                                         @onclick:preventDefault="true"
                                         class="header-dropdown-summary h-10 px-3 rounded-lg bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 shadow-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors text-sm font-semibold">
                                    @(L.CurrentLanguage == "uk" ? "UK" : "EN") ▾
                                </summary>
                                <div class="header-dropdown-menu absolute right-0 mt-2 w-24 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl z-50 p-1">
                                    <button @onclick='@(() => SetLanguageAsync("en"))'
                                            class="w-full px-3 py-2 rounded-md text-left text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        EN
                                    </button>
                                    <button @onclick='@(() => SetLanguageAsync("uk"))'
                                            class="w-full px-3 py-2 rounded-md text-left text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        UK
                                    </button>
                                </div>
                            </details>

                            <button @onclick="Theme.ToggleTheme"
                                    class="theme-toggle p-2 rounded-lg bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 shadow-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors"
                                    title="@L.Translate("theme.toggle")">
                                @if (Theme.IsDarkMode)
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                                    </svg>
                                }
                            </button>

                            <div class="notification-wrapper relative @(HasNewNotificationPulse ? "has-new" : "")">
                                <button @onclick="ToggleNotificationsAsync"
                                        class="theme-toggle p-2 rounded-lg bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 shadow-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors relative"
                                        title="@L.Translate("notifications.title")">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V4a2 2 0 10-4 0v1.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                                    </svg>
                                    @if (UnreadNotificationsCount > 0)
                                    {
                                        <span class="notification-badge">@UnreadNotificationsCount</span>
                                    }
                                </button>

                                @if (IsNotificationsOpen)
                                {
                                    <div class="notification-dropdown notification-dropdown-enter absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl z-50">
                                        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 dark:border-gray-700">
                                            <span class="text-sm font-semibold text-gray-800 dark:text-white">@L.Translate("notifications.title")</span>
                                            @if (UnreadNotificationsCount > 0)
                                            {
                                                <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline" @onclick="MarkNotificationsAsReadAsync">@L.Translate("notifications.markAllRead")</button>
                                            }
                                        </div>

                                        <div class="max-h-80 overflow-y-auto">
                                            @if (!Notifications.Any())
                                            {
                                                <div class="px-4 py-6 text-sm text-center text-gray-500 dark:text-gray-400">@L.Translate("notifications.empty")</div>
                                            }
                                            else
                                            {
                                                @foreach (var item in Notifications)
                                                {
                                                    <div class="notification-item @(item.IsRead ? "" : "is-unread")">
                                                        <button class="notification-open-btn" @onclick="() => OpenNotificationAsync(item)">
                                                            <span class="notification-message">@item.Message</span>
                                                            <span class="notification-time">@FormatNotificationTime(item.CreatedAt)</span>
                                                        </button>
                                                        <button class="notification-delete-btn"
                                                                title="@L.Translate("notifications.delete")"
                                                                @onclick="() => DeleteNotificationAsync(item.Id)">
                                                            ✕
                                                        </button>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <details class="header-dropdown relative">
                                <summary class="header-dropdown-summary flex items-center gap-3 pl-2 sm:pl-3 border-l border-gray-200 dark:border-gray-600 cursor-pointer">
                                    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center shadow-lg">
                                        <span class="text-white font-semibold text-sm">
                                            @(AuthService.CurrentUser?.Login?.Substring(0, 1).ToUpper() ?? "U")
                                        </span>
                                    </div>
                                    <span class="hidden sm:inline text-sm font-medium text-gray-800 dark:text-white">
                                        @(AuthService.CurrentUser?.Role.ToString() ?? AuthService.CurrentUser?.Login)
                                    </span>
                                </summary>

                                <div class="header-dropdown-menu absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl z-50 p-1">
                                    <NavLink href="profile"
                                             class="block w-full px-3 py-2 rounded-md text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        @L.Translate("profile.title")
                                    </NavLink>
                                    <button @onclick="HandleLogout"
                                            class="w-full flex items-center gap-2 px-3 py-2 rounded-md text-left text-sm text-gray-700 dark:text-gray-200 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                        </svg>
                                        @L.Translate("common.logout")
                                    </button>
                                </div>
                            </details>
                        </div>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto bg-gray-100 dark:bg-gray-900 transition-colors duration-200">
                    @Body
                </main>
            </div>
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<ToastContainer Toasts="ToastService.Toasts" OnRemoveToast="ToastService.RemoveToastAsync" />
