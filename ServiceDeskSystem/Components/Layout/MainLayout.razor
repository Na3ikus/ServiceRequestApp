@inherits LayoutComponentBase
@using ServiceDeskSystem.Application.Services
@inject IAuthService AuthService
@inject ILocalizationService L
@inject IThemeService Theme
@inject NavigationManager Navigation
@implements IDisposable

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="@(Theme.IsDarkMode ? "dark" : "")">
    @if (!authRestored)
    {
        <div class="flex items-center justify-center h-screen bg-gray-100">
            <div class="text-gray-500">@L.Translate("common.loading")</div>
        </div>
    }
    else if (!AuthService.IsAuthenticated)
    {
        @Body
        <RedirectToLogin />
    }
    else
    {
        <div class="flex h-screen bg-gray-100 dark:bg-gray-900 transition-colors duration-200 overflow-hidden relative">
            
            <!-- Mobile Overlay Backdrop -->
            @if (isSidebarOpen)
            {
                <div class="fixed inset-0 bg-gray-900/60 dark:bg-black/60 backdrop-blur-sm z-40 lg:hidden transition-opacity duration-300" 
                     @onclick="CloseSidebar"></div>
            }

            <!-- Sidebar -->
            <aside class="fixed inset-y-0 left-0 z-50 w-64 transform transition-transform duration-300 ease-in-out lg:static lg:translate-x-0 @(isSidebarOpen ? "translate-x-0" : "-translate-x-full") shadow-2xl lg:shadow-none flex-shrink-0">
                <NavMenu />
            </aside>

            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                <header class="sticky top-0 z-30 bg-white/80 dark:bg-gray-800/80 backdrop-blur-md shadow-sm border-b border-gray-200/50 dark:border-gray-700/50 transition-colors duration-200">
                    <div class="flex items-center justify-between px-4 lg:px-6 py-4">
                        <div class="flex items-center gap-4">
                            <!-- Mobile Hamburger Button -->
                            <button @onclick="ToggleSidebar" class="p-2 -ml-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 lg:hidden focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                                </svg>
                            </button>
                            
                            <div class="hidden sm:block">
                                <h2 class="text-lg font-semibold text-gray-800 dark:text-white leading-tight">@L.Translate("dashboard.welcome")</h2>
                                <p class="text-xs text-gray-500 dark:text-gray-400">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
                            </div>
                        </div>

                        <div class="header-actions flex items-center gap-2 sm:gap-3">
                            <div class="lang-toggle relative rounded-full flex items-center">
                                <div class="lang-toggle-slider @(L.CurrentLanguage == "uk" ? "slide-right" : "")"></div>
                                <button @onclick="@(() => L.SetLanguage("en"))"
                                        class="lang-toggle-btn relative z-10 text-sm font-bold rounded-full transition-colors duration-300 text-center @(L.CurrentLanguage == "en" ? "text-gray-900 dark:text-white" : "text-white/90 hover:text-white")">
                                    EN
                                </button>
                                <button @onclick="@(() => L.SetLanguage("uk"))"
                                        class="lang-toggle-btn relative z-10 text-sm font-bold rounded-full transition-colors duration-300 text-center @(L.CurrentLanguage == "uk" ? "text-gray-900 dark:text-white" : "text-white/90 hover:text-white")">
                                    UK
                                </button>
                            </div>

                            <button @onclick="Theme.ToggleTheme"
                                    class="theme-toggle p-2 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
                                    title="@L.Translate("theme.toggle")">
                                @if (Theme.IsDarkMode)
                                {
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                                        </svg>
                                }
                                else
                                {
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                                        </svg>
                                }
                            </button>

                            <NavLink href="profile" class="flex items-center gap-3 pl-3 border-l border-gray-200 dark:border-gray-600 hover:opacity-80 transition-opacity cursor-pointer">
                                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center shadow-lg">
                                    <span class="text-white font-semibold text-sm">
                                        @(AuthService.CurrentUser?.Login?.Substring(0, 1).ToUpper() ?? "U")
                                    </span>
                                </div>
                                <div class="hidden sm:block text-left">
                                    <p class="text-sm font-medium text-gray-800 dark:text-white">@AuthService.CurrentUser?.Login</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">@AuthService.CurrentUser?.Role</p>
                                </div>
                            </NavLink>

                            <button @onclick="HandleLogout"
                                    class="logout-btn flex items-center gap-2 px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                </svg>
                                <span class="hidden sm:inline">@L.Translate("common.logout")</span>
                            </button>
                        </div>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto bg-gray-100 dark:bg-gray-900 transition-colors duration-200">
                    @Body
                </main>
            </div>
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool authRestored;
    private bool isSidebarOpen = false;

    protected override void OnInitialized()
    {
        L.LanguageChanged += OnStateChanged;
        Theme.ThemeChanged += OnStateChanged;
        AuthService.AuthStateChanged += OnStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !authRestored)
        {
            await Theme.InitializeAsync();
            await AuthService.EnsureRestoredAsync();
            authRestored = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnStateChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);
    
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (isSidebarOpen)
        {
            isSidebarOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleSidebar() => isSidebarOpen = !isSidebarOpen;
    
    private void CloseSidebar() => isSidebarOpen = false;

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        L.LanguageChanged -= OnStateChanged;
        Theme.ThemeChanged -= OnStateChanged;
        AuthService.AuthStateChanged -= OnStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
