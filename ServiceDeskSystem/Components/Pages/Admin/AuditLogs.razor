@page "/audit-logs"
@inherits BaseComponent
@rendermode InteractiveServer

<div class="audit-logs-container max-w-7xl mx-auto p-4 sm:p-6">
    @if (AuthService.CurrentUser?.Role != "Admin")
    {
        <div class="bg-red-100 dark:bg-red-900/30 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-400 px-6 py-4 rounded-xl">
            <div class="flex items-center gap-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                    </path>
                </svg>
                <span class="font-medium">@L.Translate("admin.accessDenied")</span>
            </div>
        </div>
    }
    else
    {
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-800 via-gray-900 to-black rounded-3xl shadow-lg p-6 sm:p-8 mb-6 border border-white/10 dark:border-gray-800 group">
            <div class="absolute top-0 right-0 -mr-10 -mt-10 w-48 h-48 rounded-full bg-white/5 blur-2xl pointer-events-none group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="relative z-10">
                <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2 tracking-tight flex items-center gap-3">
                    <span class="p-2 bg-white/10 rounded-lg backdrop-blur-sm inline-flex">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </span>
                    @L.Translate("audit.title")
                </h1>
                <p class="text-gray-400 text-sm sm:text-base flex flex-wrap items-center gap-2">
                    @L.Translate("audit.subtitle")
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                        @L.Translate("audit.autoRefreshActive")
                    </span>
                </p>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-between items-center mb-6 bg-white dark:bg-gray-800/80 backdrop-blur-sm p-4 rounded-2xl border border-gray-200 dark:border-gray-700/50 shadow-sm">
            <div class="relative w-full sm:max-w-md">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-gray-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </span>
                <input type="text" @bind-value="searchTerm" @bind-value:event="oninput"
                       placeholder="@L.Translate("audit.searchPlaceholder")"
                       style="padding-left: 2.5rem;"
                       class="w-full pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" />
            </div>

            <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                @if (showClearConfirm)
                {
                    <span class="text-xs text-red-500 dark:text-red-400 font-medium">@L.Translate("audit.clearConfirm")</span>
                    <button @onclick="ConfirmClearLogsAsync" class="px-3 py-1.5 bg-red-600 text-white rounded-lg hover:bg-red-700 text-xs font-semibold transition-colors shadow-sm">
                        @L.Translate("audit.clearYes")
                    </button>
                    <button @onclick="CancelClearLogs" style="background-color: #4b5563; color: #ffffff;" class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-all shadow-sm hover:opacity-90">
                        @L.Translate("audit.clearCancel")
                    </button>
                }
                else
                {
                    <button @onclick="RequestClearLogs" class="px-4 py-2 bg-red-50/80 dark:bg-red-950/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-900/50 rounded-xl hover:bg-red-100/80 dark:hover:bg-red-950/40 text-xs font-bold transition-all shadow-sm flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        @L.Translate("audit.clearLogs")
                    </button>
                }
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6">
            @if (logs is null)
            {
                <div class="flex justify-center py-10">
                    <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-indigo-600"></div>
                </div>
            }
            else if (!FilteredLogs.Any())
            {
                <div class="text-center py-10 text-gray-500 dark:text-gray-400">
                    @L.Translate("audit.noLogs")
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b border-gray-200 dark:border-gray-700">
                                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">@L.Translate("audit.timestamp")</th>
                                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">@L.Translate("audit.user")</th>
                                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">@L.Translate("audit.action")</th>
                                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">@L.Translate("audit.entity")</th>
                                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">@L.Translate("audit.details")</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-700/50">
                            @foreach (var log in FilteredLogs)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                    <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400 whitespace-nowrap">
                                        @log.Timestamp.ToLocalTime().ToString("g")
                                    </td>
                                    <td class="px-4 py-3 text-sm">
                                        <div class="flex items-center gap-2">
                                            <div class="w-7 h-7 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-700 dark:text-indigo-300 text-xs font-bold">
                                                @(log.User?.Login?[..1].ToUpper() ?? "?")
                                            </div>
                                            <span class="text-gray-700 dark:text-gray-300">@(log.User?.Login ?? "System")</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-sm">
                                        <span class="px-2 py-1 rounded-md text-xs font-medium @GetActionClass(log.Action)">
                                            @log.Action
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
                                        @log.EntityName (@log.EntityId)
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">
                                        <div class="max-w-xs truncate" title="@log.Changes">
                                            @log.Changes
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>
