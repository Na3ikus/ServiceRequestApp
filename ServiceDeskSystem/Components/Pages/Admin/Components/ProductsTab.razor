@inherits BaseComponent

<div class="bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-800 dark:text-white">@L.Translate("admin.products")</h2>
        <button @onclick="ShowAddProduct"
            class="px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            @L.Translate("admin.addProduct")
        </button>
    </div>

    @if (Products is null)
    {
        <div class="text-gray-500 dark:text-gray-400">@L.Translate("common.loading")</div>
    }
    else
    {
        <div class="admin-table-container">
            <table class="admin-table products-table w-full">
                <thead class="bg-gray-50 dark:bg-gray-700/50">
                    <tr>
                        <th class="col-id px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">ID</th>
                        <th class="col-name px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">@L.Translate("admin.name")</th>
                        <th class="col-description px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">@L.Translate("admin.description")</th>
                        <th class="col-version px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">@L.Translate("admin.version")</th>
                        <th class="col-techstack px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">@L.Translate("admin.techStack")</th>
                        <th class="col-actions px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">@L.Translate("admin.actions")</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    @foreach (var product in Products)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                            <td class="col-id px-4 py-3 text-sm text-gray-500 dark:text-gray-400 font-mono">@product.Id</td>
                            <td class="col-name px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">@product.Name</td>
                            <td class="col-description px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                                <div class="truncate" title="@product.Description">@product.Description</div>
                            </td>
                            <td class="col-version px-4 py-3 text-sm text-gray-500 dark:text-gray-400">@product.CurrentVersion</td>
                            <td class="col-techstack px-4 py-3 text-sm">
                                <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 rounded-md text-xs inline-block">
                                    @product.TechStack?.Name
                                </span>
                            </td>
                            <td class="col-actions px-4 py-3">
                                <div class="flex gap-2">
                                    <button @onclick="@(() => EditProduct(product))"
                                        class="admin-edit-btn p-2 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-lg transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </button>
                                    <button @onclick="@(() => DeleteProduct(product))"
                                        class="admin-delete-btn p-2 rounded-lg transition-colors @(product.Tickets?.Count > 0 ? "text-gray-400 dark:text-gray-600 cursor-not-allowed opacity-50" : "text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30")"
                                        disabled="@(product.Tickets?.Count > 0)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content admin-modal-content animate-fade-in" @onclick:stopPropagation>
            <button @onclick="CloseModal"
                class="admin-modal-close absolute top-4 right-4 z-10 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <div class="admin-modal-header mb-5 pr-10">
                <div class="flex items-start gap-3">
                    <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800 dark:text-white">@modalTitle</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            Configure product details and link it to a tech stack.
                        </p>
                    </div>
                </div>
            </div>

            <div class="admin-modal-body space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.name")</label>
                    <input type="text" @bind="editingProduct.Name"
                        class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.description")</label>
                    <textarea @bind="editingProduct.Description" rows="3"
                        class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.version")</label>
                    <input type="text" @bind="editingProduct.CurrentVersion"
                        class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.techStack")</label>
                    <select @bind="editingProduct.TechStackId"
                        class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                        @foreach (var ts in TechStacks ?? [])
                        {
                            <option value="@ts.Id">@ts.Name (@ts.Type)</option>
                        }
                    </select>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-4 p-3 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-lg text-sm border border-red-200 dark:border-red-800/40">
                    @errorMessage
                </div>
            }

            <div class="admin-modal-footer flex justify-end gap-3 mt-6">
                <button @onclick="CloseModal"
                    class="px-4 py-2 text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700/70 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg font-medium transition-colors">
                    @L.Translate("common.cancel")
                </button>
                <button @onclick="SaveModal" disabled="@isSaving"
                    class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors flex items-center gap-2">
                    @if (isSaving)
                    {
                        <svg class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>@L.Translate("common.saving")</span>
                    }
                    else
                    {
                        <span>@L.Translate("common.save")</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
