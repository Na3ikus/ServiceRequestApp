@page "/admin"
@using ServiceDeskSystem.Components.Features
@inherits BaseComponent
@rendermode InteractiveServer

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="admin-panel-container max-w-7xl mx-auto p-4 sm:p-6">
    @if (AuthService.CurrentUser?.Role != "Admin")
    {
            <div
                class="bg-red-100 dark:bg-red-900/30 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-400 px-6 py-4 rounded-xl">
                <div class="flex items-center gap-3">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                        </path>
                    </svg>
                    <span class="font-medium">@L.Translate("admin.accessDenied")</span>
                </div>
            </div>
    }
    else
    {
            <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-blue-700 to-indigo-800 rounded-3xl shadow-lg p-6 sm:p-8 mb-6 border border-white/10 dark:border-gray-800 group">
                <div class="absolute top-0 right-0 -mr-10 -mt-10 w-48 h-48 rounded-full bg-white/10 blur-2xl pointer-events-none group-hover:scale-110 transition-transform duration-700"></div>
                <div class="absolute bottom-0 left-0 -ml-10 -mb-10 w-64 h-64 rounded-full bg-blue-500/20 blur-2xl pointer-events-none group-hover:scale-110 transition-transform duration-700"></div>

                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div class="text-white">
                            <h1 class="text-2xl sm:text-3xl font-extrabold mb-1 tracking-tight flex items-center gap-3">
                                <div class="p-2 bg-white/10 rounded-lg backdrop-blur-sm">
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                </div>
                                @L.Translate("admin.title")
                            </h1>
                            <p class="text-indigo-100 text-sm sm:text-base">@L.Translate("admin.subtitle")</p>
                        </div>
                    </div>

                    <div class="admin-stats-grid grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <div class="admin-stat-card bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
                            <div class="text-xs uppercase tracking-wide text-indigo-100">@L.Translate("admin.products")</div>
                            <div class="text-2xl font-bold text-white">@(products?.Count ?? 0)</div>
                        </div>
                        <div class="admin-stat-card bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
                            <div class="text-xs uppercase tracking-wide text-indigo-100">@L.Translate("admin.techStacks")</div>
                            <div class="text-2xl font-bold text-white">@(techStacks?.Count ?? 0)</div>
                        </div>
                        <div class="admin-stat-card bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
                            <div class="text-xs uppercase tracking-wide text-indigo-100">@L.Translate("admin.users")</div>
                            <div class="text-2xl font-bold text-white">@(users?.Count ?? 0)</div>
                        </div>
                        <div class="admin-stat-card admin-stat-card-smtp bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
                            <div class="text-xs uppercase tracking-wide text-indigo-100">SMTP</div>
                            <div class="mt-1 flex items-center justify-between gap-2">
                                <span class="smtp-health-flag @(smtpCheckSuccess == true ? "is-ok" : smtpCheckSuccess == false ? "is-fail" : "is-unknown")">
                                    <span class="smtp-health-dot"></span>
                                    @(isCheckingSmtp ? "Checking..." : smtpCheckSuccess == true ? "Connected" : smtpCheckSuccess == false ? "No connection" : "Unknown")
                                </span>
                                <button @onclick="CheckSmtpStatusFromCardAsync"
                                        class="smtp-health-refresh-btn"
                                        disabled="@isCheckingSmtp">
                                    Check
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Navigation -->
            <div class="admin-tab-nav hidden md:flex items-center gap-2 mb-6 overflow-x-auto pb-1 bg-white dark:bg-gray-800/80 rounded-2xl p-2 border border-gray-200 dark:border-gray-700/50 shadow-sm">
                <button @onclick="@(() => SetActiveTab("products"))"
                    class="admin-tab-btn px-4 py-2 rounded-xl font-semibold transition-all @(activeTab == "products" ? "is-active bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg" : "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")">
                @L.Translate("admin.products")
                </button>
                <button @onclick="@(() => SetActiveTab("techstacks"))"
                    class="admin-tab-btn px-4 py-2 rounded-xl font-semibold transition-all @(activeTab == "techstacks" ? "is-active bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg" : "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")">
                @L.Translate("admin.techStacks")
                </button>
                <button @onclick="@(() => SetActiveTab("users"))"
                    class="admin-tab-btn px-4 py-2 rounded-xl font-semibold transition-all @(activeTab == "users" ? "is-active bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg" : "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")">
                @L.Translate("admin.users")
                </button>
                <button @onclick="@(() => SetActiveTab("smtp"))"
                    class="admin-tab-btn px-4 py-2 rounded-xl font-semibold transition-all @(activeTab == "smtp" ? "is-active bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg" : "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")">
                    SMTP
                </button>
            </div>

            <div class="md:hidden mb-4">
                <button @onclick="ToggleQuickAdminMenu"
                        class="w-full px-4 py-3 rounded-xl bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-700 shadow-sm flex items-center justify-between">
                    <span class="font-medium">Адмін-панель</span>
                    <svg class="w-5 h-5 transition-transform @(isQuickAdminMenuOpen ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
            </div>

        <div @key="activeTab" class="admin-tab-content">
            @if (activeTab == "products")
            {
                    <!-- Products Section -->
                    <div
                        class="bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">@L.Translate("admin.products")</h2>
                            <button @onclick="ShowAddProduct"
                                class="px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                        @L.Translate("admin.addProduct")
                            </button>
                        </div>

                @if (products is null)
                {
                                <div class="text-gray-500 dark:text-gray-400">@L.Translate("common.loading")</div>
                }
                else
                {
                                <div class="admin-table-container">
                                    <table class="admin-table products-table w-full">
                                        <thead class="bg-gray-50 dark:bg-gray-700/50">
                                            <tr>
                                                <th
                                                    class="col-id px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                                    ID</th>
                                                <th
                                                    class="col-name px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.name")</th>
                                                <th
                                                    class="col-description px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.description")</th>
                                                <th
                                                    class="col-version px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.version")</th>
                                                <th
                                                    class="col-techstack px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.techStack")</th>
                                                <th
                                                    class="col-actions px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.actions")</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                @foreach (var product in products)
                                {
                                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                                                        <td class="col-id px-4 py-3 text-sm text-gray-500 dark:text-gray-400 font-mono">@product.Id</td>
                                                        <td class="col-name px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">@product.Name
                                                        </td>
                                                        <td class="col-description px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                                                            <div class="truncate" title="@product.Description">@product.Description</div>
                                                        </td>
                                                        <td class="col-version px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                                            @product.CurrentVersion</td>
                                                        <td class="col-techstack px-4 py-3 text-sm">
                                                            <span
                                                                class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 rounded-md text-xs inline-block">
                                                @product.TechStack?.Name
                                                            </span>
                                                        </td>
                                                        <td class="col-actions px-4 py-3">
                                                            <div class="flex gap-2">
                                                                <button @onclick="@(() => EditProduct(product))"
                                                                    class="admin-edit-btn p-2 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-lg transition-colors">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                                <button @onclick="@(() => DeleteProduct(product))"
                                                                    class="admin-delete-btn p-2 rounded-lg transition-colors @(product.Tickets?.Count > 0 ? "text-gray-400 dark:text-gray-600 cursor-not-allowed opacity-50" : "text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30")"
                                                                    disabled="@(product.Tickets?.Count > 0)">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                }
                                        </tbody>
                                    </table>
                                </div>
                }
                    </div>
            }
            else if (activeTab == "techstacks")
            {
                    <!-- Tech Stacks Section -->
                    <div
                        class="bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">@L.Translate("admin.techStacks")</h2>
                            <button @onclick="ShowAddTechStack"
                                class="px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                        @L.Translate("admin.addTechStack")
                            </button>
                        </div>

                @if (techStacks is null)
                {
                                <div class="text-gray-500 dark:text-gray-400">@L.Translate("common.loading")</div>
                }
                else
                {
                                <div class="admin-table-container">
                                    <table class="admin-table techstacks-table w-full">
                                        <thead class="bg-gray-50 dark:bg-gray-700/50">
                                            <tr>
                                                <th
                                                    class="col-id px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                                    ID</th>
                                                <th
                                                    class="col-name px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.name")</th>
                                                <th
                                                    class="col-type px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.type")</th>
                                                <th
                                                    class="col-count px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.productsCount")</th>
                                                <th
                                                    class="col-actions px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.actions")</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                @foreach (var techStack in techStacks)
                                {
                                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                                                        <td class="col-id px-4 py-3 text-sm text-gray-500 dark:text-gray-400 font-mono">@techStack.Id
                                                        </td>
                                                        <td class="col-name px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">@techStack.Name
                                                        </td>
                                                        <td class="col-type px-4 py-3 text-sm text-gray-500 dark:text-gray-400">@techStack.Type</td>
                                                        <td class="col-count px-4 py-3 text-sm">
                                                            <span
                                                                class="px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-md inline-block">
                                                @(techStack.Products?.Count ?? 0)
                                                            </span>
                                                        </td>
                                                        <td class="col-actions px-4 py-3">
                                                            <div class="flex gap-2">
                                                                <button @onclick="@(() => EditTechStack(techStack))"
                                                                    class="admin-edit-btn p-2 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-lg transition-colors">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                                <button @onclick="@(() => DeleteTechStack(techStack))"
                                                                    class="admin-delete-btn p-2 rounded-lg transition-colors @(techStack.Products?.Count > 0 ? "text-gray-400 dark:text-gray-600 cursor-not-allowed opacity-50" : "text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30")"
                                                                    disabled="@(techStack.Products?.Count > 0)">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                }
                                        </tbody>
                                    </table>
                                </div>
                }
                    </div>
            }
            else if (activeTab == "users")
            {
                    <!-- Users Section -->
                    <div
                        class="admin-content-section bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">@L.Translate("admin.users")</h2>
                        </div>

                @if (users is null)
                {
                                <div class="text-gray-500 dark:text-gray-400">@L.Translate("common.loading")</div>
                }
                else
                {
                                <div class="admin-table-container">
                                    <table class="admin-table users-table w-full">
                                        <thead class="bg-gray-50 dark:bg-gray-700/50">
                                            <tr>
                                                <th
                                                    class="col-id px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                                    ID</th>
                                                <th
                                                    class="col-login px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.login")</th>
                                                <th
                                                    class="col-fullname px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.fullName")</th>
                                                <th
                                                    class="col-role px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.role")</th>
                                                <th
                                                    class="col-status px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.status")</th>
                                                <th
                                                    class="col-actions px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                        @L.Translate("admin.actions")</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                @foreach (var user in users)
                                {
                                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                                                        <td class="col-id px-4 py-3 text-sm text-gray-500 dark:text-gray-400 font-mono">@user.Id</td>
                                                        <td class="col-login px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">@user.Login
                                                        </td>
                                                        <td class="col-fullname px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                                            @($"{user.Person.FirstName} {user.Person.LastName}")
                                                        </td>
                                                        <td class="col-role px-4 py-3 text-sm">
                                                            <select @bind="user.Role" @bind:after="@(() => UpdateUserRole(user.Id, user.Role))"
                                                                disabled="@(!CanEditUserRole(user))"
                                                                class="w-full px-2 py-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-md text-xs @(!CanEditUserRole(user) ? "opacity-50 cursor-not-allowed" : "")">
                                                                <option value="Admin">@L.Translate("admin.roleAdmin")</option>
                                                                <option value="Developer">@L.Translate("admin.roleDeveloper")</option>
                                                                <option value="User">@L.Translate("admin.roleUser")</option>
                                                            </select>
                                                        </td>
                                                        <td class="col-status px-4 py-3 text-sm">
                                                            <button @onclick="@(() => ToggleUserStatus(user.Id))"
                                                                disabled="@(!CanToggleUserStatus(user))"
                                                                class="w-full px-3 py-1 rounded-full text-xs font-medium transition-colors @(!CanToggleUserStatus(user) ? "opacity-50 cursor-not-allowed" : "") @(user.IsActive ? "bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400" : "bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-400")">
                                                @(user.IsActive ? L.Translate("admin.active") : L.Translate("admin.inactive"))
                                                            </button>
                                                        </td>
                                                        <td class="col-actions px-4 py-3">
                                                            <div class="flex gap-2 justify-center">
                                                                <button @onclick="@(() => DeleteUser(user))"
                                                                    class="admin-delete-btn p-2 rounded-lg transition-colors @(!CanDeleteUser(user) ? "text-gray-400 dark:text-gray-600 cursor-not-allowed opacity-50" : "text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30")"
                                                                    disabled="@(!CanDeleteUser(user))">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                }
                                        </tbody>
                                    </table>
                                </div>
                }
                    </div>
            }
            else if (activeTab == "smtp")
            {
            <div class="admin-content-section bg-white dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-transparent dark:border-gray-700/50 p-6 space-y-6">
                <div>
                    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">SMTP Integration</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Verify SMTP connectivity and send a test email.</p>
                </div>

                <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50/80 dark:bg-gray-900/40 space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h3 class="font-medium text-gray-800 dark:text-white">Connection health</h3>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Checks SMTP host, port and authentication.</p>
                        </div>
                        <button @onclick="CheckSmtpAsync" disabled="@isCheckingSmtp"
                                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                            @(isCheckingSmtp ? "Checking..." : "Check connection")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(smtpCheckMessage))
                    {
                        <div class="text-sm px-3 py-2 rounded-lg @(smtpCheckSuccess == true ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400" : "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400")">
                            @smtpCheckMessage
                        </div>
                    }
                </div>

                <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50/80 dark:bg-gray-900/40 space-y-4">
                    <div>
                        <h3 class="font-medium text-gray-800 dark:text-white">Test email</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400">Sends a test message using current SMTP settings.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Recipient email</label>
                            <input type="email" @bind="smtpTestRecipient"
                                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subject</label>
                            <input type="text" @bind="smtpTestSubject"
                                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <button @onclick="SendSmtpTestEmailAsync" disabled="@isSendingTestEmail"
                                class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                            @(isSendingTestEmail ? "Sending..." : "Send test email")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(smtpSendMessage))
                    {
                        <div class="text-sm px-3 py-2 rounded-lg @(smtpSendSuccess == true ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400" : "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400")">
                            @smtpSendMessage
                        </div>
                    }
                </div>
            </div>
            }
        </div>
    }
</div>

@if (AuthService.CurrentUser?.Role == "Admin")
{
    <div class="admin-quick-nav md:hidden @(isQuickAdminMenuOpen ? "open" : "")">
        <div class="admin-quick-nav-overlay" @onclick="CloseQuickAdminMenu"></div>
        <div class="admin-quick-nav-sheet">
            <div class="admin-quick-nav-header">
                <span class="font-semibold text-gray-800 dark:text-white">Адмін-панель</span>
                <button @onclick="CloseQuickAdminMenu"
                        class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <div class="admin-quick-nav-grid">
                <button @onclick="@(() => SetActiveTabFromQuickMenu("products"))"
                        class="admin-quick-nav-item @(activeTab == "products" ? "is-active" : "")">
                    @L.Translate("admin.products")
                </button>
                <button @onclick="@(() => SetActiveTabFromQuickMenu("techstacks"))"
                        class="admin-quick-nav-item @(activeTab == "techstacks" ? "is-active" : "")">
                    @L.Translate("admin.techStacks")
                </button>
                <button @onclick="@(() => SetActiveTabFromQuickMenu("users"))"
                        class="admin-quick-nav-item @(activeTab == "users" ? "is-active" : "")">
                    @L.Translate("admin.users")
                </button>
                <button @onclick="@(() => SetActiveTabFromQuickMenu("smtp"))"
                        class="admin-quick-nav-item @(activeTab == "smtp" ? "is-active" : "")">
                    SMTP
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal - moved outside for proper z-index layering -->
@if (showModal)
{
        <div class="modal-overlay" @onclick="CloseModal">
            <div class="modal-content admin-modal-content animate-fade-in" @onclick:stopPropagation>
                <!-- Close button -->
                <button @onclick="CloseModal"
                    class="admin-modal-close absolute top-4 right-4 z-10 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>

                <div class="admin-modal-header mb-5 pr-10">
                    <div class="flex items-start gap-3">
                        <div class="w-11 h-11 rounded-xl flex items-center justify-center @(modalType == "product" ? "bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300" : "bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-300")">
                            @if (modalType == "product")
                            {
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                </svg>
                            }
                            else
                            {
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.427 1.756 2.925 0 3.352a1.724 1.724 0 00-1.066 2.572c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.427 1.756-2.925 1.756-3.352 0a1.724 1.724 0 00-2.572-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.427-1.756-2.925 0-3.352a1.724 1.724 0 001.066-2.572c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 100-6 3 3 0 000 6z"></path>
                                </svg>
                            }
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-gray-800 dark:text-white">@modalTitle</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                                @(modalType == "product" ? "Configure product details and link it to a tech stack." : "Configure tech stack name and type.")
                            </p>
                        </div>
                    </div>
                </div>

            @if (modalType == "product")
            {
                        <div class="admin-modal-body space-y-4">
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.name")</label>
                                <input type="text" @bind="editingProduct.Name"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                            </div>
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.description")</label>
                                <textarea @bind="editingProduct.Description" rows="3"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white resize-none"></textarea>
                            </div>
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.version")</label>
                                <input type="text" @bind="editingProduct.CurrentVersion"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                            </div>
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.techStack")</label>
                                <select @bind="editingProduct.TechStackId"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                            @foreach (var ts in techStacks ?? [])
                            {
                                            <option value="@ts.Id">@ts.Name (@ts.Type)</option>
                            }
                                </select>
                            </div>
                        </div>
            }
            else if (modalType == "techstack")
            {
                        <div class="admin-modal-body space-y-4">
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.name")</label>
                                <input type="text" @bind="editingTechStack.Name"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                            </div>
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L.Translate("admin.type")</label>
                                <input type="text" @bind="editingTechStack.Type"
                                    class="admin-modal-field w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                            </div>
                        </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                        <div class="mt-4 p-3 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-lg text-sm border border-red-200 dark:border-red-800/40">
                    @errorMessage
                        </div>
            }

                <div class="admin-modal-footer flex justify-end gap-3 mt-6">
                    <button @onclick="CloseModal"
                        class="px-4 py-2 text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700/70 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors">
                    @L.Translate("admin.cancel")
                    </button>
                    <button @onclick="SaveModal"
                        class="px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-lg hover:from-blue-700 hover:to-indigo-700 transition-colors shadow-md"
                        disabled="@isSaving">
                    @if (isSaving)
                    {
                                <span>@L.Translate("admin.saving")</span>
                    }
                    else
                    {
                                <span>@L.Translate("admin.save")</span>
                    }
                    </button>
                </div>
            </div>
        </div>

}

<!-- Toast Notifications -->
<ToastContainer Toasts="Toasts" OnRemoveToast="RemoveToastAsync" />
