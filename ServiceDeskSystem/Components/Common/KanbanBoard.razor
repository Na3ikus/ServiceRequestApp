@using ServiceDeskSystem.Domain.Entities
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

@inherits ServiceDeskSystem.Components.Common.BaseComponent
@implements IAsyncDisposable

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="kanban-board overflow-x-auto pb-4">
    <div class="flex gap-4 min-w-max h-full">
        @foreach (var column in Columns)
        {
            var col = column;
            var colTickets = GetTicketsForColumn(col.Status);

            <div class="kanban-column flex flex-col w-72 flex-shrink-0">
                <!-- Column Header -->
                <div class="flex items-center justify-between mb-3 px-1">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full @col.DotColor flex-shrink-0"></div>
                        <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">
                            @GetStatusText(col.Status)
                        </span>
                    </div>
                    <span class="inline-flex items-center justify-center min-w-[24px] h-6 px-2 rounded-full 
                                 bg-gray-200 dark:bg-gray-700 text-xs font-bold text-gray-600 dark:text-gray-300">
                        @colTickets.Count
                    </span>
                </div>

                <!-- Drop Zone (column body) -->
                <div class="kanban-drop-zone flex-1 min-h-[200px] rounded-2xl p-2 space-y-2
                            bg-gray-100/80 dark:bg-gray-800/50 border-2 border-transparent
                            transition-all duration-200"
                     @ref="dropZoneRefs[col.Status]">

                    @if (colTickets.Count == 0)
                    {
                        <div class="flex items-center justify-center h-24 text-xs text-gray-400 dark:text-gray-600 italic select-none">
                            @L.Translate("kanban.noTickets")
                        </div>
                    }
                    else
                    {
                        @foreach (var ticket in colTickets)
                        {
                            <KanbanCard Ticket="ticket"
                                        CanDrag="@CanUserDragTicket(ticket)" />
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly KanbanColumnDef[] Columns =
    [
        new("New",         "bg-purple-500"),
        new("Open",        "bg-blue-500"),
        new("In Progress", "bg-amber-500"),
        new("Testing",     "bg-cyan-500"),
        new("Code Review", "bg-indigo-500"),
        new("Done",        "bg-emerald-500"),
        new("Resolved",    "bg-green-500"),
        new("Closed",      "bg-gray-500"),
    ];

    private readonly Dictionary<string, ElementReference> dropZoneRefs = new();
    private DotNetObjectReference<KanbanBoard>? dotnetRef;

    [Parameter, EditorRequired]
    public List<Ticket> Tickets { get; set; } = [];

    /// <summary>Current user ID — needed to determine if a card is draggable.</summary>
    [Parameter]
    public int CurrentUserId { get; set; }

    /// <summary>If true, Admin can drag any ticket.</summary>
    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public EventCallback<(int TicketId, string NewStatus)> OnStatusChanged { get; set; }

    // Initialize drop zones by status key
    private void EnsureDropZoneRef(string status)
    {
        if (!dropZoneRefs.ContainsKey(status))
            dropZoneRefs[status] = default;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        foreach (var col in Columns)
            EnsureDropZoneRef(col.Status);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotnetRef = DotNetObjectReference.Create(this);
            foreach (var col in Columns)
            {
                if (dropZoneRefs.TryGetValue(col.Status, out var el))
                {
                    await JSRuntime.InvokeVoidAsync("kanban.initDropZone", el, dotnetRef, col.Status);
                }
            }
        }
    }

    /// <summary>Called from JS when a ticket is dropped onto a column.</summary>
    [JSInvokable]
    public async Task OnTicketDropped(int ticketId, string newStatus)
    {
        if (OnStatusChanged.HasDelegate)
        {
            await OnStatusChanged.InvokeAsync((ticketId, newStatus));
        }
    }

    private List<Ticket> GetTicketsForColumn(string status)
        => Tickets.Where(t => t.Status == status).ToList();

    private bool CanUserDragTicket(Ticket ticket)
        => IsAdmin || ticket.DeveloperId == CurrentUserId;

    public async ValueTask DisposeAsync()
    {
        dotnetRef?.Dispose();
        await Task.CompletedTask;
    }

    private record KanbanColumnDef(string Status, string DotColor);
}
