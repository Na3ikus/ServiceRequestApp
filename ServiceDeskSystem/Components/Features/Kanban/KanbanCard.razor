@using ServiceDeskSystem.Domain.Entities
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

@inherits ServiceDeskSystem.Components.UI.Base.BaseComponent

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="kanban-card @(CanDrag ? "cursor-grab active:cursor-grabbing" : "cursor-pointer") 
     bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700/60 
     p-4 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 hover:border-blue-300 dark:hover:border-blue-600/60"
@ref="cardElement" draggable="@(CanDrag ? "true" : "false")" @onclick="HandleClick">

    <!-- Header: ID + Priority -->
    <div class="flex items-start justify-between gap-2 mb-2">
        <span class="text-xs font-mono text-gray-400 dark:text-gray-500 flex-shrink-0">#@Ticket.Id</span>
        <span class="@GetPriorityBadgeClass(Ticket.Priority) px-2 py-0.5 rounded text-xs font-semibold flex-shrink-0">
            @GetPriorityText(Ticket.Priority)
        </span>
    </div>

    <!-- Title -->
    <p class="text-sm font-semibold text-gray-800 dark:text-white line-clamp-2 leading-snug mb-3">
        @Ticket.Title
    </p>

    <!-- Footer: Author + Assignee -->
    <div class="flex items-center justify-between gap-2 mt-auto">
        <!-- Author avatar -->
        <div class="flex items-center gap-1.5">
            <div
                class="w-5 h-5 rounded-full bg-gradient-to-br from-gray-400 to-gray-600 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-[9px] font-bold">@(Ticket.Author?.Login?.Substring(0, 1).ToUpper() ??
                    "?")</span>
            </div>
            <span class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[70px]">@Ticket.Author?.Login</span>
        </div>

        <!-- Assignee or unassigned -->
        @if (Ticket.Developer is not null)
        {
            <div class="flex items-center gap-1">
                <div
                    class="w-5 h-5 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center flex-shrink-0">
                    <span class="text-white text-[9px] font-bold">@(Ticket.Developer.Login?.Substring(0, 1).ToUpper() ??
                    "?")</span>
                </div>
                <span
                    class="text-xs text-green-600 dark:text-green-400 truncate max-w-[70px]">@Ticket.Developer.Login</span>
            </div>
        }
        else
        {
            <span class="text-xs text-gray-400 dark:text-gray-500 italic">@L.Translate("table.unassigned")</span>
        }
    </div>
</div>

@code {
    private ElementReference cardElement;
    private string _lastInitializedStatus = string.Empty;
    private bool _lastCanDrag = false;

    [Parameter, EditorRequired]
    public Ticket Ticket { get; set; } = null!;

    [Parameter]
    public bool CanDrag { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-initialize draggable whenever CanDrag is true and the status or drag permission changed.
        // This is critical: after a card moves to a new column Blazor re-renders it with new Ticket.Status,
        // but firstRender is false, so without this check the JS listener would still report the old sourceStatus.
        if (CanDrag && (firstRender || Ticket.Status != _lastInitializedStatus || CanDrag != _lastCanDrag))
        {
            _lastInitializedStatus = Ticket.Status;
            _lastCanDrag = CanDrag;
            await JSRuntime.InvokeVoidAsync("kanban.initDraggable", cardElement, Ticket.Id, Ticket.Status);
        }
    }

    private void HandleClick()
    {
        Navigation.NavigateTo($"/ticket/{Ticket.Id}");
    }
}
