@page "/statistics"
@using ServiceDeskSystem.Domain.Entities
@using Microsoft.JSInterop
@inherits ServiceDeskSystem.Components.UI.Base.BaseComponent
@rendermode InteractiveServer

<!-- Created by Nazar "N1h3" Hutsol -->
<div class="max-w-7xl mx-auto p-6">

    @if (!HasAccess)
    {
        <div
            class="bg-red-100 dark:bg-red-900/50 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-300 px-6 py-4 rounded-xl">
            <div class="flex items-center gap-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                    </path>
                </svg>
                <span class="font-medium">@L.Translate("stats.accessDenied")</span>
            </div>
        </div>
    }
    else if (isLoading)
    {
        <div class="animate-pulse">
            <!-- Page Header -->
            <div class="mb-8">
                <div class="h-8 bg-gray-200 dark:bg-gray-700 rounded w-48 mb-2"></div>
                <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-64"></div>
            </div>

            <!-- Top Summary Cards -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-5 border border-transparent dark:border-gray-700/50">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16 mb-3"></div>
                                <div class="h-8 bg-gray-200 dark:bg-gray-700 rounded w-12"></div>
                            </div>
                            <div class="h-12 w-12 bg-gray-200 dark:bg-gray-700 rounded-xl"></div>
                        </div>
                    </div>
                }
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-transparent dark:border-gray-700/50">
                        <div class="h-5 bg-gray-200 dark:bg-gray-700 rounded w-32 mb-5"></div>
                        <div class="w-full h-64 bg-gray-200 dark:bg-gray-700 rounded-full mx-auto" style="max-width: 256px;"></div>
                    </div>
                }
            </div>
            
            <!-- Top Developers -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-transparent dark:border-gray-700/50">
                <div class="h-5 bg-gray-200 dark:bg-gray-700 rounded w-32 mb-5"></div>
                <div class="space-y-4">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="flex items-center gap-4">
                            <div class="h-8 w-8 bg-gray-200 dark:bg-gray-700 rounded text-center"></div>
                            <div class="flex-1">
                                <div class="flex justify-between items-center mb-1">
                                    <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-24"></div>
                                    <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-16"></div>
                                </div>
                                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-800 dark:text-white">@L.Translate("stats.title")</h1>
            <p class="text-gray-600 dark:text-gray-400">@L.Translate("stats.subtitle")</p>
        </div>

        <!-- Top Summary Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <!-- Total -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-xl hover:shadow-blue-500/20 transition-all duration-300 hover:-translate-y-1">
                <div class="p-5">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">
                                @L.Translate("stats.total")</p>
                            <p class="text-3xl font-bold text-gray-900 dark:text-white" id="totalCount">@totalTickets</p>
                        </div>
                        <div
                            class="p-3 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl shadow-lg shadow-blue-500/30">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="h-1 bg-gradient-to-r from-blue-500 to-blue-600"></div>
            </div>

            <!-- Open -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-xl hover:shadow-amber-500/20 transition-all duration-300 hover:-translate-y-1">
                <div class="p-5">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">
                                @L.Translate("stats.open")</p>
                            <p class="text-3xl font-bold text-gray-900 dark:text-white" id="openCount">@openTickets</p>
                        </div>
                        <div
                            class="p-3 bg-gradient-to-br from-amber-500 to-orange-500 rounded-xl shadow-lg shadow-amber-500/30">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="h-1 bg-gradient-to-r from-amber-500 to-orange-500"></div>
            </div>

            <!-- Critical -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-xl hover:shadow-red-500/20 transition-all duration-300 hover:-translate-y-1">
                <div class="p-5">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">
                                @L.Translate("stats.critical")</p>
                            <p class="text-3xl font-bold text-gray-900 dark:text-white" id="criticalCount">@criticalTickets</p>
                        </div>
                        <div class="p-3 bg-gradient-to-br from-red-500 to-rose-600 rounded-xl shadow-lg shadow-red-500/30">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="h-1 bg-gradient-to-r from-red-500 to-rose-600"></div>
            </div>

            <!-- Resolved -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-xl hover:shadow-emerald-500/20 transition-all duration-300 hover:-translate-y-1">
                <div class="p-5">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">
                                @L.Translate("stats.resolved")</p>
                            <p class="text-3xl font-bold text-gray-900 dark:text-white" id="resolvedCount">@resolvedTickets</p>
                        </div>
                        <div
                            class="p-3 bg-gradient-to-br from-emerald-500 to-green-600 rounded-xl shadow-lg shadow-emerald-500/30">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="h-1 bg-gradient-to-r from-emerald-500 to-green-600"></div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

            <!-- By Status -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-transparent dark:border-gray-700/50">
                <h2 class="text-base font-semibold text-gray-700 dark:text-white mb-5">@L.Translate("stats.byStatus")</h2>
                <div class="relative w-full h-64">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>

            <!-- By Priority -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-transparent dark:border-gray-700/50">
                <h2 class="text-base font-semibold text-gray-700 dark:text-white mb-5">@L.Translate("stats.byPriority")</h2>
                <div class="relative w-full h-64">
                    <canvas id="priorityChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Developers -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 border border-transparent dark:border-gray-700/50">
            <h2 class="text-base font-semibold text-gray-700 dark:text-white mb-5">@L.Translate("stats.topDevs")</h2>
            @if (!topDevs.Any())
            {
                <p class="text-sm text-gray-400 dark:text-gray-500 italic">@L.Translate("stats.noData")</p>
            }
            else
            {
                var maxCount = topDevs.Max(d => d.Count);
                <div class="space-y-4">
                    @foreach (var (i, dev) in topDevs.Select((d, i) => (i, d)))
                    {
                        var pct = Pct(dev.Count, maxCount);
                        var medal = i switch { 0 => "🥇", 1 => "🥈", 2 => "🥉", _ => $"#{i + 1}" };
                        <div class="flex items-center gap-4">
                            <span class="text-lg w-8 flex-shrink-0 text-center">@medal</span>
                            <div class="flex-1">
                                <div class="flex justify-between items-center mb-1">
                                    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">@dev.Login</span>
                                    <span class="text-sm font-bold text-emerald-600 dark:text-emerald-400">@dev.Count
                                        @L.Translate("stats.tickets")</span>
                                </div>
                                <div class="w-full bg-gray-100 dark:bg-gray-700 rounded-full h-2.5 overflow-hidden">
                                    <div class="h-2.5 rounded-full bg-gradient-to-r from-emerald-500 to-green-500 transition-all duration-700"
                                        style="width: @(pct)%"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
