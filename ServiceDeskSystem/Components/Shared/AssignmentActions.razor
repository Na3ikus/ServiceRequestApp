@using ServiceDeskSystem.Domain.Entities
@using ServiceDeskSystem.Application.Services.Localization
@inject ILocalizationService L

<!-- Assignment Actions Component -->
@if (ShowTakeButton || ShowReleaseButton)
{
    <div class="bg-white dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-md border border-gray-200 dark:border-gray-700 p-6 sm:p-8 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 dark:bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/10 dark:group-hover:bg-blue-500/20 transition-colors pointer-events-none"></div>

        <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-5 flex items-center gap-2 relative z-10">
            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
            </svg>
            @L.Translate("details.assignment")
        </h3>
        
        <div class="space-y-3 relative z-10 flex flex-col">
            @if (ShowTakeButton)
            {
                <button @onclick="OnTakeTicket" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl transition-all shadow-sm backdrop-blur-md whitespace-nowrap group text-sm font-medium border bg-blue-50 hover:bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-500/10 dark:hover:bg-blue-500/20 dark:text-blue-400 dark:border-blue-500/30">
                    <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                    </svg>
                    <span>@L.Translate("details.takeTicket")</span>
                </button>
            }

            @if (ShowReleaseButton)
            {
                <button @onclick="OnReleaseTicket" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl transition-all shadow-sm backdrop-blur-md whitespace-nowrap group text-sm font-medium border bg-red-50 hover:bg-red-100 text-red-700 border-red-200 dark:bg-red-500/10 dark:hover:bg-red-500/20 dark:text-red-400 dark:border-red-500/30">
                    <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"></path>
                    </svg>
                    <span>@L.Translate("details.releaseTicket")</span>
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Ticket? Ticket { get; set; }

    [Parameter]
    public int CurrentUserId { get; set; }

    [Parameter]
    public bool IsAdminOrDeveloper { get; set; }

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public EventCallback OnTakeTicket { get; set; }

    [Parameter]
    public EventCallback OnReleaseTicket { get; set; }

    /// <summary>
    /// Show Take button if: ticket is free AND user is admin or developer.
    /// </summary>
    private bool ShowTakeButton =>
        Ticket?.DeveloperId is null && IsAdminOrDeveloper;

    /// <summary>
    /// Show Release button if: ticket is assigned to current user (admin can only release their own tickets).
    /// </summary>
    private bool ShowReleaseButton =>
        Ticket?.DeveloperId is not null &&
        Ticket.DeveloperId == CurrentUserId;
}

