@inject ILocalizationService L
@inject IThemeService Theme
@inject IAuthService AuthService
@implements IDisposable

<!-- Created by Nazar "N1h3" Hutsol -->
<nav class="sidebar-root @(IsCollapsed ? "is-collapsed" : string.Empty) @(Theme.IsDarkMode ? "is-dark" : string.Empty)">
    <div class="sidebar-brand">
        <a href="" class="brand-link" aria-label="@L.Translate("nav.serviceDesk")">
            <div class="brand-icon">
                <svg class="brand-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
            </div>
            <span class="brand-title">@L.Translate("nav.serviceDesk")</span>
        </a>

        <button type="button"
                class="collapse-btn"
                @onclick="ToggleCollapseAsync"
                aria-label="@(IsCollapsed ? "Розгорнути меню" : "Згорнути меню")">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="@(IsCollapsed ? "M13 5l7 7-7 7M5 5l7 7-7 7" : "M11 19l-7-7 7-7M19 19l-7-7 7-7")" />
            </svg>
        </button>
    </div>

    <div class="sidebar-content">
        @foreach (var menuSection in _sections)
        {
            <section class="menu-section">
                <button type="button"
                        class="section-toggle"
                        @onclick="() => ToggleSection(menuSection.Id)"
                        aria-expanded="@(menuSection.IsExpanded.ToString().ToLowerInvariant())">
                    <span class="section-title">@menuSection.Title</span>
                    <svg class="section-chevron @(menuSection.IsExpanded ? "expanded" : string.Empty)" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>

                <ul class="menu-list @((menuSection.IsExpanded || IsCollapsed) ? "open" : string.Empty)">
                    @foreach (var item in menuSection.Items)
                    {
                        <li>
                            <NavLink href="@item.Url"
                                     Match="@item.Match"
                                     class="menu-link"
                                     ActiveClass="active"
                             data-tooltip="@item.Title"
                             aria-label="@item.Title">
                                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@GetIconPath(item.IconKey)" />
                                </svg>
                                <span class="menu-label">@item.Title</span>
                            </NavLink>
                        </li>
                    }
                </ul>
            </section>
        }
    </div>

    <div class="sidebar-footer">
        <span class="footer-text">@L.Translate("common.footer")</span>
    </div>
</nav>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback ToggleCollapseRequested { get; set; }

    private List<MenuSection> _sections = [];

    protected override void OnInitialized()
    {
        L.LanguageChanged += OnStateChanged;
        Theme.ThemeChanged += OnStateChanged;
    }

    protected override void OnParametersSet()
    {
        BuildMenu();
    }

    private async Task ToggleCollapseAsync()
    {
        if (ToggleCollapseRequested.HasDelegate)
        {
            await ToggleCollapseRequested.InvokeAsync();
        }
    }

    private void BuildMenu()
    {
        var role = AuthService.CurrentUser?.Role;

        var general = new MenuSection("general", "General")
        {
            Items =
            {
                new MenuItem("home", L.Translate("nav.home"), string.Empty, "home", NavLinkMatch.All)
            }
        };

        var workspace = new MenuSection("workspace", "Workspace");

        if (role is "Admin" or "Developer")
        {
            workspace.Items.Add(new MenuItem("tickets", L.Translate("nav.allTickets"), "tickets", "tickets", NavLinkMatch.All));
        }

        if (role == "User")
        {
            workspace.Items.Add(new MenuItem("myTickets", L.Translate("nav.myTickets"), "my-tickets", "user", NavLinkMatch.All));
        }

        var management = new MenuSection("management", "Administration");

        if (role == "Developer")
        {
            management.Items.Add(new MenuItem("developer", L.Translate("nav.developer"), "developer", "code"));
            management.Items.Add(new MenuItem("statistics", L.Translate("nav.statistics"), "statistics", "chart"));
        }

        if (role == "Admin")
        {
            management.Items.Add(new MenuItem("developer", L.Translate("nav.myTickets"), "developer", "tickets"));
            management.Items.Add(new MenuItem("statistics", L.Translate("nav.statistics"), "statistics", "chart"));
            management.Items.Add(new MenuItem("admin", L.Translate("nav.admin"), "admin", "settings"));
        }

        _sections = new List<MenuSection> { general, workspace, management }
            .Where(s => s.Items.Count > 0)
            .ToList();
    }

    private void ToggleSection(string sectionId)
    {
        var section = _sections.FirstOrDefault(s => s.Id == sectionId);
        if (section is null)
        {
            return;
        }

        section.IsExpanded = !section.IsExpanded;
    }

    private static string GetIconPath(string key) => key switch
    {
        "home" => "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
        "tickets" => "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01",
        "user" => "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
        "code" => "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
        "chart" => "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
        "settings" => "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
        _ => "M5 12h14"
    };

    private void OnStateChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.LanguageChanged -= OnStateChanged;
        Theme.ThemeChanged -= OnStateChanged;
    }

    private sealed class MenuSection(string id, string title)
    {
        public string Id { get; } = id;
        public string Title { get; } = title;
        public List<MenuItem> Items { get; } = [];
        public bool IsExpanded { get; set; } = true;
    }

    private sealed record MenuItem(string Id, string Title, string Url, string IconKey, NavLinkMatch Match = NavLinkMatch.Prefix);
}

