@page "/profile"
@inherits ServiceDeskSystem.Components.Common.Base.BaseComponent
@using ServiceDeskSystem.Application.Services.Localization.Interfaces
@using ServiceDeskSystem.Application.Services.Profile.Interfaces
@using ServiceDeskSystem.Application.Services.Profile.Models
@using ServiceDeskSystem.Application.Services.Auth.Interfaces
@using Microsoft.AspNetCore.Components.Forms

<div class="max-w-4xl mx-auto p-6">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden transition-colors">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@(L.Translate("profile.title") ?? "Мій профіль")</h1>
            @if (isSaved)
            {
                    <span class="text-green-600 dark:text-green-400 text-sm font-medium flex items-center gap-1 transition-opacity duration-300">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    @(L.Translate("profile.saved") ?? "Збережено")
                    </span>
            }
        </div>

        <div class="p-6">
            @if (isLoading)
            {
                    <div class="flex justify-center py-10">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                    </div>
            }
            else if (errorMessage != null)
            {
                    <div class="bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 p-4 rounded-lg mb-6">
                    @errorMessage
                    </div>
            }
            else if (model != null)
            {
                    <EditForm Model="model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <!-- Ім'я -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                @(L.Translate("profile.firstName") ?? "Ім'я")
                                </label>
                                <InputText @bind-Value="model.FirstName" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors" />
                            </div>

                            <!-- Прізвище -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                @(L.Translate("profile.lastName") ?? "Прізвище")
                                </label>
                                <InputText @bind-Value="model.LastName" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors" />
                            </div>

                            <!-- По батькові -->
                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                @(L.Translate("profile.middleName") ?? "По батькові")
                                </label>
                                <InputText @bind-Value="model.MiddleName" 
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors" />
                            </div>

                            <!-- Опис (Bio) -->
                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                @(L.Translate("profile.bio") ?? "Одесь (Bio)")
                                </label>
                                <InputTextArea @bind-Value="model.Bio" rows="4"
                                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors"
                                    placeholder="@(L.Translate("profile.bioPlaceholder") ?? "Розкажіть трохи про себе...")" />
                            </div>
                        </div>

                        <div class="mb-6">
                            <div class="flex justify-between items-center mb-4">
                                <h3 class="text-lg font-medium text-gray-900 dark:text-white">@(L.Translate("profile.contacts.title") ?? "Контакти")</h3>
                                <button type="button" @onclick="AddContact" 
                                    class="px-3 py-1.5 text-sm bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-medium rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors flex items-center gap-1">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                @(L.Translate("profile.contacts.add") ?? "Додати контакт")
                                </button>
                            </div>

                            <div class="space-y-3">
                            @foreach (var contact in model.Contacts)
                            {
                                        <div class="flex gap-3 items-start bg-gray-50 dark:bg-gray-800/50 p-3 rounded-lg border border-gray-100 dark:border-gray-700">
                                            <div class="w-1/3">
                                                <InputSelect @bind-Value="contact.ContactTypeId" 
                                                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors">
                                                    <option value="0">@(L.Translate("profile.contacts.selectType") ?? "Оберіть тип")</option>
                                            @foreach (var t in contactTypes)
                                            {
                                                            <option value="@t.Id">@t.Name</option>
                                            }
                                                </InputSelect>
                                            </div>
                                            <div class="flex-1">
                                                <InputText @bind-Value="contact.Value" placeholder="@(L.Translate("profile.contacts.valuePlaceholder") ?? "Значення...")"
                                                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors" />
                                            </div>
                                            <button type="button" @onclick="(() => RemoveContact(contact))"
                                                class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors" title="@(L.Translate("profile.contacts.delete") ?? "Видалити")">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                            </button>
                                        </div>
                            }

                            @if (!model.Contacts.Any())
                            {
                                        <div class="text-center py-6 text-gray-500 dark:text-gray-400 text-sm">
                                    @(L.Translate("profile.contacts.noContacts") ?? "Немає доданих контактів.")
                                        </div>
                            }
                            </div>
                        </div>

                        <div class="flex justify-end pt-4 border-t border-gray-100 dark:border-gray-700">
                            <button type="submit" disabled="@isSaving"
                                    class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-medium rounded-xl shadow-lg shadow-blue-500/30 transition-all disabled:opacity-50 flex items-center gap-2">
                            @if (isSaving)
                            {
                                        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                        </svg>
                                        <span>@(L.Translate("profile.saving") ?? "Збереження...")</span>
                            }
                            else
                            {
                                        <span>@(L.Translate("profile.saveChanges") ?? "Зберегти зміни")</span>
                            }
                            </button>
                        </div>
                    </EditForm>
            }
        </div>
    </div>
</div>
